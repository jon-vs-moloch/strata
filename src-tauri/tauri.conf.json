{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Strata",
  "version": "0.1.0",
  "identifier": "ai.strata.desktop",
  "build": {
    "beforeDevCommand": "bash ./scripts/desktop_dev_frontend.sh",
    "beforeBuildCommand": "npm run build --prefix strata_ui",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../strata_ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Strata",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
